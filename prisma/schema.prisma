generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

model PrismaConnection {
  name String @id
}

model SeedLog {
  id        Int     @id @default(autoincrement())
  name      String
  completed Boolean @default(false)
}

datasource db {
  provider = "postgresql"
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model Admin {
  id         Int       @id @default(autoincrement())
  username   String    @unique @db.VarChar(255)
  password   String    @db.VarChar(255)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  ECStaff    ECStaff[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model Candidate {
  id              Int          @id @default(autoincrement())
  title           String       @db.VarChar(50)
  first_name      String       @db.VarChar(255)
  last_name       String       @db.VarChar(255)
  number          Int
  image_url       String       @db.VarChar(500)
  party_id        Int
  constituency_id Int
  created_at      DateTime?    @default(now()) @db.Timestamp(6)
  Constituency    Constituency @relation(fields: [constituency_id], references: [id], onUpdate: NoAction)
  Party           Party        @relation(fields: [party_id], references: [id], onUpdate: NoAction)
  Vote            Vote[]

  @@unique([constituency_id, number])
  @@index([constituency_id], map: "idx_candidate_constituency_id")
  @@index([party_id], map: "idx_candidate_party_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model Constituency {
  id              Int         @id @default(autoincrement())
  province        String      @db.VarChar(255)
  district_number Int
  is_closed       Boolean?    @default(false)
  created_at      DateTime?   @default(now()) @db.Timestamp(6)
  Candidate       Candidate[]
  User            User[]
  ECStaff         ECStaff[]

  @@unique([province, district_number])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model Party {
  id         Int         @id @default(autoincrement())
  name       String      @unique @db.VarChar(255)
  logo_url   String      @db.VarChar(500)
  policy     String
  created_at DateTime?   @default(now()) @db.Timestamp(6)
  Candidate  Candidate[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model User {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  national_id     String       @unique @db.VarChar(13)
  password        String       @db.VarChar(255)
  title           String       @db.VarChar(50)
  first_name      String       @db.VarChar(255)
  last_name       String       @db.VarChar(255)
  address         String
  constituency_id Int
  created_at      DateTime?    @default(now()) @db.Timestamp(6)
  Constituency    Constituency @relation(fields: [constituency_id], references: [id], onUpdate: NoAction)
  Vote            Vote?

  @@index([constituency_id], map: "idx_user_constituency_id")
  @@index([national_id], map: "idx_user_national_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model Vote {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String     @unique @db.Uuid
  candidate_id Int?
  created_at   DateTime?  @default(now()) @db.Timestamp(6)
  updated_at   DateTime?  @default(now()) @db.Timestamp(6)
  Candidate    Candidate? @relation(fields: [candidate_id], references: [id], onUpdate: NoAction)
  User         User       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([candidate_id], map: "idx_vote_candidate_id")
  @@index([created_at], map: "idx_vote_created_at")
  @@index([user_id], map: "idx_vote_user_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model ECStaff {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  admin_id        Int
  national_id     String       @unique @db.VarChar(13)
  password        String       @db.VarChar(255)
  title           String       @db.VarChar(50)
  first_name      String       @db.VarChar(255)
  last_name       String       @db.VarChar(255)
  email           String?      @db.VarChar(255)
  constituency_id Int
  status          ec_status?   @default(ACTIVE)
  created_at      DateTime?    @default(now()) @db.Timestamp(6)
  updated_at      DateTime?    @default(now()) @db.Timestamp(6)
  Admin           Admin        @relation(fields: [admin_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Constituency    Constituency @relation(fields: [constituency_id], references: [id], onUpdate: NoAction)

  @@index([admin_id], map: "idx_ecstaff_admin_id")
  @@index([national_id], map: "idx_ecstaff_national_id")
  @@index([constituency_id], map: "idx_ecstaff_constituency_id")
  @@index([status], map: "idx_ecstaff_status")
}

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  action    String   @db.VarChar(255)
  entity    String   @db.VarChar(255)
  entity_id String?  @db.VarChar(255)
  user_id   String?  @db.Uuid
  details   String?  @db.Text
  ip_address String? @db.VarChar(45)
  created_at DateTime @default(now()) @db.Timestamp(6)

  @@index([action], map: "idx_audit_action")
  @@index([entity], map: "idx_audit_entity")
  @@index([user_id], map: "idx_audit_user_id")
  @@index([created_at], map: "idx_audit_created_at")
}

enum user_role {
  VOTER
}

enum ec_status {
  ACTIVE
  INACTIVE
}
