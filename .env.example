# Database
DATABASE_URL=postgresql://username:password@localhost:5432/mydatabase
DIRECT_URL=postgresql://username:password@localhost:5432/mydatabase

# JWT
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=7d

# Supabase
SUPABASE_URL=https://your-project.supabase.co/storage/v1/s3
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET_NAME=election-bucket
SUPABASE_ENDPOINT_URL=https://your-project.supabase.co/storage/v1/s3
SUPABASE_SECRET=your-supabase-secret-key

# AWS S3 Credentials (for file uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-northeast-1

# File Upload
S3_BUCKET=election-bucket
UPLOAD_DIR=uploads

# Server
PORT=3000
